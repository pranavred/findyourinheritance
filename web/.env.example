# OpenAI API key — used by /api/match to generate the "ancestor" line.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Vectorize REST API
CLOUDFLARE_ACCOUNT_ID=2b74de6a0193e9b285489a1d6ed1647c
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VECTORIZE_INDEX=historical-portraits

# ElevenLabs text-to-speech for the ancestor's voice line.
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional voice overrides. The route picks based on gender inferred from the
# matched figure's bio (counts he/him vs she/her pronouns). Defaults below are
# verified-available voices on the connected ElevenLabs account.
#   Male default   = Bill ("wise, mature, balanced")     pqHfZKP75CvOlQylNhV4
#   Female default = Matilda ("knowledgable, professional") XrExE9yKIg1WjnnlVkGX
# Set ELEVENLABS_VOICE_ID to force a single voice for everyone (overrides both).
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_VOICE_ID_MALE=pqHfZKP75CvOlQylNhV4
# ELEVENLABS_VOICE_ID_FEMALE=XrExE9yKIg1WjnnlVkGX

# Replicate API token — used for veed/fabric-1.0 (image+audio → talking video).
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to the venv Python that has face_recognition installed.
PYTHON_PATH=../venv/bin/python
